# URL of the backend API. Leave unset to default to window.location.origin.
VITE_SERVER_API_BASE_URL=http://localhost:8000

# Default UI theme ("light" or "dark").
VITE_DEFAULT_THEME=dark

# Allow users to self-register (true/false).
VITE_ALLOW_SELF_REGISTER=true

# Layout style ("topnav" or "drawer").
VITE_LAYOUT=topnav

# OpenRVDAS version string shown in the UI.
# In production this should be set from the version field in the parent
# OpenRVDAS repo's pyproject.toml (e.g. via the build pipeline).
# For local development any string works.
VITE_OPENRVDAS_VERSION=dev
